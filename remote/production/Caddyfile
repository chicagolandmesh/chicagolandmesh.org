{
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
}

(logging) {
	log {
		output file /logs/caddy.log
	}
}

chicagolandmesh.org {
	import logging
	log_skip /tiles/*

	encode

	root /srv

	handle_errors 404 {
		rewrite /404.html
		file_server
	}

	handle /api/* {
		reverse_proxy map-api:8080
	}

	handle_path /tiles/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy pmtiles:8080
	}

	handle_path /hashicon/* {
		header Cache-Control "no-cache"
		reverse_proxy hashicon:3000
	}

	handle /discord {
		redir {env.DISCORD_INVITE_URL} permanent
	}

	handle {
		handle /assets/* {
			header Cache-Control "public, max-age=86400, stale-while-revalidate=604800"

			@fingerprinted path_regexp fingerprinted "^(.*/)?[^/]+\.[a-fA-F0-9]{6,32}(?:\.min)?\.(js|css)$"
			handle @fingerprinted {
				header Cache-Control "public, max-age=31536000, immutable"
			}

			handle /assets/external/* {
				header Cache-Control "public, max-age=31536000, immutable"
			}
		}

		header Cache-Control "public, max-age=3600, must-revalidate"
		file_server
	}
}

*.chicagolandmesh.org {
	import logging

	encode

	handle_errors 502 {
		header Content-Type "text/html"
		respond "<center><h1>{err.status_code} {err.status_text}<h1><center>"
	}

	@www host www.chicagolandmesh.org
	handle @www {
		redir https://chicagolandmesh.org{uri} permanent
	}

	@meshview host meshview.chicagolandmesh.org
	handle @meshview {
		header Cache-Control "no-cache"
		reverse_proxy {env.MESHVIEW_ADDR}
	}

	handle {
		abort
	}
}

chimesh.org {
	import logging

	redir https://chicagolandmesh.org{uri} permanent
}

*.chimesh.org {
	import logging

	redir https://{labels.2}.chicagolandmesh.org{uri} permanent
}
